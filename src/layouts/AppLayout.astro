---
import '../styles/tokens.css';
import '../styles/effects.css';
import '../styles/hero-chart.css';
import '../styles/perf.css';
import '../styles/layout.css';
import '../components/user-menu.css';
import AppShellHeader from '../components/AppShellHeader.astro';
import AuthGate from '../components/AuthGate';
import ProfileLangBootstrap from '../components/ProfileLangBootstrap';

interface Props {
  title?: string;
  fullHeight?: boolean;
}

const { title = 'ATCS Tools', fullHeight = false } = Astro.props;
const shellClass = fullHeight ? 'shell shell-full' : 'shell';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        try {
          var v = localStorage.getItem('atcs_global_lang');
          window.__ATCS_LANG = v === 'en' ? 'en' : 'zh';
          document.documentElement.lang = window.__ATCS_LANG === 'zh' ? 'zh-CN' : 'en';
        } catch (e) {
          window.__ATCS_LANG = 'zh';
        }
        document.addEventListener('visibilitychange', function () {
          if (document.hidden) document.documentElement.setAttribute('data-tab-hidden', 'true');
          else document.documentElement.removeAttribute('data-tab-hidden');
        });
      })();
    </script>
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%233b5f8a'/%3E%3Ctext x='16' y='22' font-size='18' text-anchor='middle' fill='%23ffffff' font-family='system-ui' font-weight='bold'%3EAT%3C/text%3E%3C/svg%3E"
    />
  </head>
  <body>
    <AuthGate client:load>
      <ProfileLangBootstrap client:load />
      <div class={shellClass}>
        <div class="page-ambient" aria-hidden="true">
          <div class="page-ambient-spot"></div>
        </div>
        <AppShellHeader />
        <main class="shell-main">
          <slot />
        </main>
      </div>
    </AuthGate>
  </body>
</html>
